/*
  Irregular geodesic triangulated sphere (Teufelsberg triangular-radome pattern).
  Units: millimeters.  GENERATED by generate_triangulated.py - edit that, not this.

  A SOLID ball tiled with 320 triangles in a geodesic layout (pentagon nodes +
  hexagonal flowers), but the vertices are jittered so triangle size and shape
  VARY across the surface - the less-regular look of the real dome, not a uniform
  grid.  Regenerate with:  python3 generate_triangulated.py <freq> <jitter> > geosphere.scad

  Solid, not a shell: union of wedges from the center out to each triangle.
  Each triangle is inset toward its centroid by `seam`, opening a real groove
  along every edge (visible in any viewer and in a print).
*/

R    = 30;    // sphere radius (mm)
seam = 0.07;  // groove width as a fraction of each triangle (0 = no seams)

module wedge(dirs) {
  pts = [for (d = dirs) d * R];
  g   = (pts[0] + pts[1] + pts[2]) / 3;
  ins = [for (p = pts) p + (g - p) * seam];
  eps = R / 5000;
  hull() {
    sphere(eps, $fn = 4);
    for (p = ins) translate(p) sphere(eps, $fn = 4);
  }
}

