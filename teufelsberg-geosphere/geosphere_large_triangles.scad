// light strut = a cylinder a->b (far fewer triangles than a hull of two
// spheres); the node hubs cover the flat end caps.
module strut(i, j) {
  a = verts[i] * R;
  b = verts[j] * R;
  d = b - a;
  h = norm(d);
  translate(a)
    rotate([0, acos(d[2] / h), atan2(d[1], d[0])])
      cylinder(h = h, r = rim, $fn = strut_fn);
}

union() {
  if (fill) polyhedron(points = [for (p = verts) p * R], faces = faces);  // filled panels
  for (e = edges) strut(e[0], e[1]);                          // raised borders
  for (v = verts) translate(v * R) sphere(node, $fn = strut_fn);  // hubs
}
